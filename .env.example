# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/emo

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MQTT (EMQX) ────────────────────────────────────
MQTT_BROKER_URL=mqtts://mqtt.emo.local:8883
MQTT_USERNAME=emo_cloud
MQTT_PASSWORD=change_me

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# ─── Device Pairing ─────────────────────────────────
DEVICE_PAIRING_SECRET=change_me

# ─── Encryption ─────────────────────────────────────
ENCRYPTION_KEY=change_me

# ─── Notifications ──────────────────────────────────
FCM_SERVER_KEY=
